  "witnesses": [
    {
      "id": "colleague",
      "name": "Колега",
      "description": "Співробітниця того ж відділу",
      "isAvailable": true,
      "dialogue": [
        {
          "text": "Я бачив його того вечора. Він збирався додому, виглядав стомленим, але спокійним.",
          "log": {
            "type": "dialogue",
            "importance": "normal"
          }
        },
        {
          "text": "Він кілька разів питав мене про відпустку за свій рахунок.",
          "log": {
            "type": "dialogue",
            "importance": "normal"
          }
        },
        {
          "text": "Говорив, що хоче \"вийти з гри\". Я подумала, що це жарт.",
          "log": {
            "type": "dialogue",
            "importance": "normal"
          }
        },
        {
          "text": "У день зникнення він попрощався. Дивно, але спокійно.",
          "log": {
            "type": "dialogue",
            "importance": "normal"
          }
        }
      ]
    },
    {
      "id": "manager",
      "name": "HR-менеджер",
      "description": "Керівник потерпілого, відносини невідомі",
      "isAvailable": true,
      "dialogue": [
        {
          "text": "Тиск був серйозним. Проект затримувався і він це розумів.",
          "log": {
            "type": "dialogue",
            "importance": "normal"
          }
        },
        {
          "text": "Але я не думав, що він здатний просто зникнути.",
          "log": {
            "type": "dialogue",
            "importance": "hint"
          }
        }
      ]
